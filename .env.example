# ─────────────────────────────────────────
#  Telegram
# ─────────────────────────────────────────
# Get from @BotFather on Telegram
BOT_TOKEN=your_telegram_bot_token_here

# ─────────────────────────────────────────
#  Mistral
# ─────────────────────────────────────────
# Get from https://console.mistral.ai
MISTRAL_API_KEY=your_mistral_api_key_here
MISTRAL_MODEL=mistral-small-latest

# ─────────────────────────────────────────
#  MongoDB Atlas
# ─────────────────────────────────────────
# Get from Atlas → Connect → Drivers (Python)
MONGODB_URI=mongodb+srv://<user>:<password>@<cluster>.mongodb.net/jobagent

# ─────────────────────────────────────────
#  Pipeline
# ─────────────────────────────────────────
# How many days between automatic scrape+summarize runs (default: 3)
# The bot checks this on startup and sleeps until the next scheduled run.
# You can also trigger a manual run with: uv run run_pipeline.py --force
PIPELINE_INTERVAL_DAYS=3
# ─────────────────────────────────────────
# Langfuse
# ─────────────────────────────────────────
LANGFUSE_SECRET_KEY="LANGFUSE_SECRET_KEY"
LANGFUSE_PUBLIC_KEY="LANGFUSE_PUBLIC_KEY"
LANGFUSE_BASE_URL="https://cloud.langfuse.com"